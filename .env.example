# ── API ──────────────────────────────────────────────
PORT=3000

# ── PostgreSQL ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=match
DB_PASSWORD=match
DB_NAME=match_engine
# Fase 1: el esquema se crea solo. Pon "false" cuando uses migraciones (Fase 3).
DB_SYNCHRONIZE=true

# ── Redis / cola de turnos (BullMQ) ──────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
